# SaveVid AI production environment.
# Copy this file to deploy/app.env on the VPS and fill it in. Never commit app.env.
#
# These are the SAME values you already set in Render (Environment tab). Copy
# them across verbatim so the analytics DB, admin login, and salt stay identical
# and your existing data + dashboard keep working with no migration.

# --- Analytics + admin dashboard + maintenance toggle ---
# All four are required together. Without them the site still works as a
# downloader, but /admin, the analytics, and the in-dashboard maintenance
# toggle are disabled.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
ADMIN_PASSWORD=
ANALYTICS_SALT=

# --- Reddit galleries / share links (optional) ---
# Leave empty to run the anonymous Reddit path (videos, GIFs, images all work
# without these). Fill in only if you later create a Reddit "script" app.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Hard maintenance override (optional) ---
# Leave unset for normal operation. Set to 1/true to force the maintenance page
# regardless of the in-dashboard toggle. The admin toggle is the day-to-day way
# to do this; this env var is a backup.
# MAINTENANCE_MODE=
